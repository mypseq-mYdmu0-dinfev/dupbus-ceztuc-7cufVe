				<key>ActionName</key>
				<string>Run AppleScript</string>
				<key>ActionParameters</key>
				<dict>
					<key>source</key>
					<string>do shell script "open -a '/Applications/macOS InstantView.app'"
delay 60

tell application "Google Chrome" to activatedelay 3tell application "Claude" to activatedelay 3

tell application "Claude Web" to activatedelay 3tell application "System Events" to keystroke "p" using {command down, option down, control down}delay 3

tell application "macOS InstantView" to activate
delay 3
tell application "System Events" to keystroke "w" using {command down}
delay 3tell application "Preview"	activateend tellrepeat 3 times	do shell script "open -a Preview '/Users/culous/Pictures/Black/black_1.png'"	delay 1	do shell script "open -a Preview '/Users/culous/Pictures/Black/black_2.png'"	delay 1	do shell script "open -a Preview '/Users/culous/Pictures/Black/black_3.png'"	delay 1	do shell script "open -a Preview '/Users/culous/Pictures/Black/black_4.png'"	delay 3end repeattell application "System Events"	tell process "Preview"		set targetNames to {"black_1.png", "black_2.png", "black_3.png", "black_4.png"}				repeat			set pngWindows to {}			repeat with n in targetNames				try					set w to window n					if exists w then						set the end of pngWindows to w					end if				on error					-- skip				end try			end repeat						if (count of pngWindows) = 0 then exit repeat						-- Focus the FIRST matching PNG window			set w to item 1 of pngWindows			perform action "AXRaise" of w -- try to bring it to front			set value of attribute "AXFocused" of w to true			delay 3						-- Close it			try				keystroke "w" using {command down}				delay 3			on error				-- already gone; continue			end try		end repeat	end tellend telldelay 3-- Display 4do shell script "open -a Preview '/Users/culous/Pictures/Black/black_4.png'"delay 1tell application "Preview" to activatedelay 1tell application "System Events" to keystroke tab using {option down, shift down}delay 3tell application "System Events" to keystroke "f" using {command down, control down}delay 3-- Display 3do shell script "open -a Preview '/Users/culous/Pictures/Black/black_3.png'"delay 1tell application "Preview" to activatedelay 1tell application "System Events" to keystroke tab using {option down}delay 1tell application "System Events" to keystroke tab using {option down}delay 1tell application "System Events" to keystroke "f" using {command down, control down}delay 3-- Display 2do shell script "open -a Preview '/Users/culous/Pictures/Black/black_2.png'"delay 1tell application "Preview" to activatedelay 1tell application "System Events" to keystroke tab using {option down}delay 1tell application "System Events" to keystroke "f" using {command down, control down}delay 3-- Display 1do shell script "open -a Preview '/Users/culous/Pictures/Black/black_1.png'"delay 1tell application "Preview" to activatedelay 1tell application "System Events" to keystroke "f" using {command down, control down}delay 3</string>
				</dict>
