				<key>ActionName</key>
				<string>Run AppleScript</string>
				<key>ActionParameters</key>
				<dict>
					<key>source</key>
					<string>do shell script "open -a '/Applications/macOS InstantView.app'"
delay 60

tell application "macOS InstantView" to activate
delay 3
tell application "System Events" to keystroke "w" using {command down}
delay 3

tell application "Google Chrome" to activatedelay 3tell application "Claude" to activatedelay 3

tell application "Claude Web" to activatedelay 3

tell application "System Events" to keystroke "p" using {command down, option down, control down}delay 10

do shell script "pmset sleepnow"</string>
